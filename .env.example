# ------------------------------------------------------------
# Market Screener Environment Template (Day 5)
# Copy this file to `.env` and fill secrets locally.
# ------------------------------------------------------------

# Core app
APP_NAME=market-screener
APP_ENV=development
TZ=Asia/Kolkata
LOG_LEVEL=INFO
LOG_JSON=true

# Runtime services
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# Basic auth (personal dashboard access)
AUTH_ENABLED=true
AUTH_BASIC_USERNAME=prash
AUTH_BASIC_PASSWORD=change_me_strong_password

# Security
APP_SECRET_KEY=replace_with_long_random_secret

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=market_screener
POSTGRES_USER=market_user
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://market_user:change_me_postgres_password@localhost:5432/market_screener

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Provider API keys
FMP_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
MARKETAUX_API_KEY=

# Crypto provider settings
COINGECKO_API_KEY=
CCXT_EXCHANGE_ID=binance
CCXT_API_KEY=
CCXT_API_SECRET=

# Alerts (Telegram primary)
ALERT_CHANNEL_TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_MAX_PER_DAY=5
ALERT_COOLDOWN_MINUTES=60

# Optional email alerts (future use)
ALERT_CHANNEL_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
ALERT_DISPATCH_SYMBOL_LIMIT=150
ALERT_DISPATCH_LOOKBACK_HOURS=72
ALERT_DISPATCH_SIGNAL_ALLOWLIST=strong_buy,buy
ALERT_DISPATCH_MIN_SCORE=70.0

# Ingestion and scheduler (swing defaults)
INGESTION_SWING_INTERVAL_SECONDS=300
NEWS_POLL_INTERVAL_SECONDS=900
FUNDAMENTALS_REFRESH_HOURS=24
SYMBOL_UNIVERSE_FILE=config/symbols_v1.json
WATCHLIST_SYMBOLS=
MARKET_HOLIDAYS_US=
MARKET_HOLIDAYS_NSE=
MARKET_HOLIDAYS_GLOBAL=
FRESHNESS_MONITOR_TARGET_AGE_MINUTES=5
FRESHNESS_MONITOR_SYMBOL_LIMIT=20
PROVIDER_HEALTH_LOOKBACK_HOURS=24
PROVIDER_HEALTH_JOB_SAMPLE_LIMIT=500
PROVIDER_HEALTH_DASHBOARD_HISTORY_LIMIT=24
INGESTION_STRESS_SYMBOL_LIMIT=100
INDICATOR_SNAPSHOT_SYMBOL_LIMIT=150
INDICATOR_SNAPSHOT_PRICE_LOOKBACK_ROWS=260
INDICATOR_SNAPSHOT_SOURCE=ta_v1
TREND_REGIME_SYMBOL_LIMIT=150
TREND_REGIME_INDICATOR_SOURCE=ta_v1
TREND_REGIME_MACD_FLAT_TOLERANCE=0.10
BREAKOUT_SYMBOL_LIMIT=150
BREAKOUT_LOOKBACK_BARS=20
BREAKOUT_BUFFER_RATIO=0.002
BREAKOUT_INDICATOR_SOURCE=ta_v1
RELATIVE_VOLUME_SYMBOL_LIMIT=150
RELATIVE_VOLUME_LOOKBACK_BARS=20
RELATIVE_VOLUME_SPIKE_THRESHOLD=1.5
RELATIVE_VOLUME_DRY_UP_THRESHOLD=0.7
FUNDAMENTALS_SNAPSHOT_SYMBOL_LIMIT=150
FUNDAMENTALS_SNAPSHOT_PERIOD_TYPE=annual
FUNDAMENTALS_SNAPSHOT_LIMIT_PER_SYMBOL=2
FUNDAMENTALS_SNAPSHOT_SOURCE=fmp_v1
NEWS_INGESTION_SYMBOL_LIMIT=150
NEWS_INGESTION_LIMIT_PER_SYMBOL=5
NEWS_INGESTION_LOOKBACK_HOURS=72
NEWS_INGESTION_LANGUAGE=en
NEWS_INGESTION_SOURCE=marketaux_v1
SENTIMENT_PIPELINE_SYMBOL_LIMIT=150
SENTIMENT_PIPELINE_LOOKBACK_HOURS=72
SENTIMENT_PIPELINE_HALF_LIFE_HOURS=24
SENTIMENT_PIPELINE_SOURCE_FILTER=marketaux_v1
EVENT_RISK_SYMBOL_LIMIT=150
EVENT_RISK_LOOKBACK_HOURS=72
EVENT_RISK_SOURCE_FILTER=marketaux_v1
EVENT_RISK_NEGATIVE_SENTIMENT_THRESHOLD=-0.35
SCORE_BACKFILL_SYMBOL_LIMIT=150
SCORE_BACKFILL_LOOKBACK_DAYS=90
SCORE_BACKFILL_INDICATOR_SOURCE=ta_v1
SCORE_BACKFILL_FUNDAMENTALS_SOURCE=fmp_v1
SCORE_BACKFILL_NEWS_SOURCE_FILTER=marketaux_v1
SCORE_BACKFILL_NEWS_LOOKBACK_HOURS=72
SCORE_BACKFILL_SENTIMENT_HALF_LIFE_HOURS=24
EQUITY_OHLCV_RESOLUTION=D
EQUITY_OHLCV_LOOKBACK_DAYS=365
CRYPTO_OHLCV_VS_CURRENCY=usd
CRYPTO_OHLCV_DAYS=365
MACRO_OHLCV_LOOKBACK_DAYS=365
MACRO_OHLCV_FOREX_OUTPUTSIZE=full
MACRO_OHLCV_COMMODITY_INTERVAL=daily
BACKFILL_VALIDATION_SYMBOL_LIMIT=20
BACKFILL_VALIDATION_LOOKBACK_DAYS=7
BACKFILL_VALIDATION_MIN_ROWS=3
BACKFILL_VALIDATION_MAX_LAST_ROW_AGE_DAYS=4
INGESTION_FAILURE_RETRY_BACKOFF_MINUTES=5,15,60
INGESTION_FAILURE_MAX_ATTEMPTS=5
INGESTION_FAILURE_RETRY_BATCH_SIZE=50

# Provider request policy (aligned with provider matrix)
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=12
HTTP_TOTAL_TIMEOUT_SECONDS=15
HTTP_RETRY_ATTEMPTS=3
HTTP_BACKOFF_SECONDS=1,2,4
PROVIDER_QUOTA_RESERVE_RATIO=0.1
FMP_QUOTA_PER_MINUTE=60
ALPHA_VANTAGE_QUOTA_PER_MINUTE=5
FINNHUB_QUOTA_PER_MINUTE=60
COINGECKO_QUOTA_PER_MINUTE=30
MARKETAUX_QUOTA_PER_MINUTE=30

# Caching and staleness controls
PRICE_CACHE_TTL_SECONDS=60
NEWS_CACHE_TTL_SECONDS=900
FUNDAMENTALS_CACHE_TTL_SECONDS=86400
MAX_STALE_PRICE_MINUTES=15
MAX_STALE_FUNDAMENTALS_DAYS=7
MAX_STALE_NEWS_HOURS=24
